NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: ingestion pipelines (snapshots, cron batch, user-triggered crawls).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Protect POST /api/v1/ingestion/cron (Vercel cron or external scheduler).
CRON_SECRET=generate-a-long-random-secret

# Optional: Firecrawl for JS-heavy pages (falls back to fetch when unset).
# FIRECRAWL_API_KEY=

# AI summarization + classification (Phase 5). Falls back to rules when unset.
ANTHROPIC_API_KEY=

# Optional org context in organizations.settings.intelligence:
# { "product_description": "...", "market": "...", "stage": "series-b" }

# Optional: allow manual intelligence event creation in production (debug / seeding).
# ALLOW_MANUAL_INTELLIGENCE_EVENTS=true
